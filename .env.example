# ── Supabase ────────────────────────────────────────────────
# Project settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, keep secret

# ── Resend (confirmation emails) ────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Verified sender. Until you verify a domain, use onboarding@resend.dev.
BOOKING_FROM_EMAIL=Axis Lab <hello@axislab.id>

# ── Site ────────────────────────────────────────────────────
# Used to build links inside emails. On Vercel this is optional
# (VERCEL_URL is used as a fallback).
NEXT_PUBLIC_SITE_URL=https://axislab.id
